  "lexical_entries": {
    "asseblief": {
      "part_of_speech": "bywoord",
      "guidance": "Gebruik dit wanneer 'n versoek beleefd gestel word.",
      "informal_alternatives": ["asb"],
      "examples": ["Stuur asseblief die dokument aan my."]
    },
    "duidelik": {
      "part_of_speech": "byvoeglike naamwoord of bywoord",
      "guidance": "Beskryf iets wat maklik verstaan of waargeneem kan word.",
      "synonyms": ["helder", "verstaanbaar"],
      "antonyms": ["onduidelik"],
      "examples": ["Die instruksies is duidelik geskryf."]
    },
    "vriendelik": {
      "part_of_speech": "byvoeglike naamwoord of bywoord",
      "guidance": "Dui 'n aangename en tegemoetkomende houding aan.",
      "synonyms": ["hartlik", "tegemoetkomend"],
      "antonyms": ["onvriendelik"],
      "examples": ["Sy het die kliënt vriendelik gehelp."]
    },
    "tans": {
      "part_of_speech": "bywoord",
      "guidance": "Formele, bondige alternatief vir 'op die oomblik'.",
      "synonyms": ["nou"],
      "informal_alternatives": ["nou"],
      "examples": ["Die kantoor is tans gesluit."]
    }
  }
