SKRYFWYS_ACME_EMAIL=admin@example.com
SKRYFWYS_POSTGRES_PASSWORD=replace-with-a-long-url-safe-random-password

AI_PROVIDER=
AI_MODEL=
AI_BASE_URL=
OPENAI_API_KEY=
AI_TIMEOUT_SECONDS=20
AI_MAX_INPUT_CHARACTERS=20000
AI_DAILY_BUDGET=0

