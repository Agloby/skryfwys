    "office-addin-manifest": "^2.1.6",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^6.0.0"
  }
}
